# Database
DATABASE_URL="postgresql://user:password@localhost:5432/edutrack"

# JWT Secrets
JWT_ACCESS_SECRET="your-super-secret-access-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV="development"

# CORS
CLIENT_URL="http://localhost:3000"

# Redis (for caching and token blacklist)
REDIS_URL="redis://localhost:6379"

# File Upload
MAX_FILE_SIZE_TEACHER=52428800
MAX_FILE_SIZE_STUDENT=10485760
UPLOAD_PATH="./uploads"

# Cloud Storage (AWS S3 or Firebase)
CLOUD_STORAGE_PROVIDER="s3"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_LOCKOUT_DURATION_MS=1800000
